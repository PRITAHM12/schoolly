{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A potential school client who requested a demo.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schoolName": { "type": "string" },
        "contactName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "contacted", "demo-scheduled", "pilot-started", "lost"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["schoolName", "contactName", "email", "phone"]
    },
    "School": {
      "title": "School",
      "description": "An active school using the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "adminEmail": { "type": "string" },
        "pilotEndDate": { "type": "string", "format": "date-time" },
        "isPaid": { "type": "boolean" }
      },
      "required": ["name", "adminEmail"]
    }
  },
  "firestore": {
    "leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of business leads"
    },
    "schools/{schoolId}": {
      "schema": "School",
      "description": "Registered schools on the platform"
    }
  }
}
